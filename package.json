    "stock-backtest": "bin/backtest.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node dev.js",
    "analyze": "node analyze.js",
    "backtest": "node backtest.js"
  },
  "keywords": [
    "stock",
    "technical-analysis",
    "A-share",
    "Taiwan-stock",
    "MACD",
    "RSI",
    "KDJ",
    "ADX",
    "backtest",
    "valuation",
    "fundamental-analysis",
    "stock-ranking"
  ],
  "author": "guiwzh",
  "license": "MIT",
  "homepage": "https://github.com/guiwzh/stock-analyzer#readme",
  "bugs": {
    "url": "https://github.com/guiwzh/stock-analyzer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guiwzh/stock-analyzer.git"
  },
  "files": [
    "bin/",
    "server.js",
    "analyze.js",
    "backtest.js",
    "dev.js",
    "indicators.js",
    "scoring.js",
    "valuation.js",
    "fundamentals.js",
    "news.js",
    "http-util.js",
    "index.html",
    "README.md"
  ],
  "engines": {
    "node": ">=14.0.0"
  }
